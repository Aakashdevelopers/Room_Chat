<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/spacing_8">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAudienceProfile"
        android:layout_width="@dimen/audience_size"
        android:layout_height="@dimen/audience_size"
        android:src="@drawable/logo_placeholder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

    <TextView
        android:id="@+id/tvAudienceName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_12"
        android:text="Audience Member"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/tvAudienceStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ivAudienceProfile"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvAudienceStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Listening..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvAudienceName"
        app:layout_constraintTop_toBottomOf="@+id/tvAudienceName" />

</androidx.constraintlayout.widget.ConstraintLayout>
