<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_explore_gradient">

    <!-- Tabs Layout -->
    <LinearLayout
        android:id="@+id/tabsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="15dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/tabSquare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSquareTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/explore_square"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <View
                android:id="@+id/activeIndicatorSquare"
                android:layout_width="20dp"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_indicator_gradient"
                android:visibility="visible" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabFollow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:id="@+id/activeIndicatorFollow"
                android:layout_width="20dp"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_indicator_gradient"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <!-- Category Filter -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/filterLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tabsLayout">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toTopOf="parent"
            tools:listitem="@layout/item_category_pill" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Post List -->

    <!-- Simple Floating Action Button -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filterLayout"
        app:layout_constraintVertical_bias="0.0"
        tools:layout_editor_absoluteX="148dp"
        tools:listitem="@layout/item_post_card" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="75dp"
        android:src="@drawable/add_button"
        app:backgroundTint="#00FFC2"
        app:fabSize="normal"
        app:maxImageSize="24dp"
        app:tint="#050C1F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation Glass Effect -->

</androidx.constraintlayout.widget.ConstraintLayout>